# Local Docker Compose (development-style stack on your machine)
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
SECRET_KEY_BASE=change_me_to_another_long_random_secret_at_least_64_chars
DATABASE_HOST=postgres
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=rails_demo_production
RAILS_ENV=production
VITE_API_URL=/api
FRONTEND_API_URL=/api
DOCKERHUB_USERNAME=your_dockerhub_username

# --- Staging EC2 (set on server or in GitHub environment "staging") ---
# DEPLOY_ENV=staging
# RAILS_ENV=staging
# DATABASE_NAME=rails_demo_staging
# Use unique JWT_SECRET and SECRET_KEY_BASE per environment.

# --- Production EC2 (set on server or in GitHub environment "production") ---
# DEPLOY_ENV=production
# RAILS_ENV=production
# DATABASE_NAME=rails_demo_production
